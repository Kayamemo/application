# ============================================================
# Environment Variables — Copy to .env and fill in your values
# ============================================================

# ─── Database ─────────────────────────────────────────────────
# Local (via docker-compose):
DATABASE_URL="postgresql://kaya:kaya_dev_password@localhost:5432/kaya_marketplace"
# Railway / Render:
# DATABASE_URL="postgresql://..."

# ─── JWT Secrets ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring $7/month price in Stripe Dashboard → Products
STRIPE_SELLER_PRICE_ID=price_...

# ─── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email ────────────────────────────────────────────────────
# Option A: Development (use Ethereal https://ethereal.email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass

# Option B: Production (SendGrid)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG...

EMAIL_FROM=noreply@kaya.app

# ─── App URLs ─────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ─── Admin Seed ───────────────────────────────────────────────
ADMIN_EMAIL=admin@kaya.app
ADMIN_PASSWORD=Admin1234!

# ─────────────────────────────────────────────────────────────
# CLIENT (.env in /client)
# ─────────────────────────────────────────────────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_API_URL=http://localhost:4000
