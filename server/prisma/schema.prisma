// ============================================================
// Prisma Schema — Kaya Marketplace
// Database: PostgreSQL
// Run: npx prisma migrate dev --name init
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING       // Payment initiated, awaiting confirmation
  ACTIVE        // Seller accepted, work in progress
  DELIVERED     // Seller marked as delivered
  COMPLETED     // Buyer confirmed delivery — funds released
  DISPUTED      // Buyer opened a dispute
  CANCELLED     // Cancelled before delivery
  REFUNDED      // Escrow refunded to buyer
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum NotificationType {
  NEW_ORDER
  ORDER_DELIVERED
  ORDER_COMPLETED
  NEW_MESSAGE
  NEW_REVIEW
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_FAILED
  REFERRAL_REWARD
}

// ─── USERS ───────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String    // bcrypt hashed
  name            String
  avatar          String?   // URL to profile image
  bio             String?
  location        String?
  role            Role      @default(BUYER)
  isVerified      Boolean   @default(false)
  verifyToken     String?
  resetToken      String?
  resetExpires    DateTime?
  stripeCustomerId String?  @unique // Stripe customer for buyers paying for services
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  sellerProfile   SellerProfile?
  buyerOrders     Order[]         @relation("BuyerOrders")
  sellerOrders    Order[]         @relation("SellerOrders")
  buyerConversations  Conversation[] @relation("BuyerConversations")
  sellerConversations Conversation[] @relation("SellerConversations")
  sentMessages    Message[]       @relation("SentMessages")
  reviewsGiven    Review[]        @relation("ReviewsGiven")
  reviewsReceived Review[]        @relation("ReviewsReceived")
  notifications   Notification[]
  referralsMade   Referral[]      @relation("Referrer")
  referredBy      Referral?       @relation("Referred")
  services        Service[]

  @@map("users")
}

// ─── SELLER PROFILE ──────────────────────────────────────────

model SellerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe subscription fields
  stripeCustomerId   String?            @unique
  stripeSubscriptionId String?          @unique
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  subscriptionEndsAt DateTime?
  trialEndsAt        DateTime?

  // Profile details
  tagline            String?            // Short headline e.g. "Expert Gardener"
  portfolioImages    String[]           // Array of image URLs
  skills             String[]
  languages          String[]           @default(["English"])
  responseTime       String?            // e.g., "Within 1 hour"
  memberSince        DateTime           @default(now())

  // Computed stats (updated via triggers/jobs)
  avgRating          Float              @default(0)
  totalReviews       Int                @default(0)
  totalOrders        Int                @default(0)
  completionRate     Float              @default(100)

  updatedAt          DateTime           @updatedAt

  @@map("seller_profiles")
}

// ─── NICHES ──────────────────────────────────────────────────

model Niche {
  id          String    @id @default(cuid())
  name        String    @unique   // e.g., "Gardening"
  slug        String    @unique   // e.g., "gardening"
  icon        String?             // emoji or icon name
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  services    Service[]

  @@map("niches")
}

// ─── SERVICES (GIGS) ─────────────────────────────────────────

model Service {
  id            String    @id @default(cuid())
  sellerId      String
  seller        User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  nicheId       String
  niche         Niche     @relation(fields: [nicheId], references: [id])

  title         String
  description   String    @db.Text
  images        String[]  // Array of image URLs
  tags          String[]
  isActive      Boolean   @default(true)

  // Location & availability
  location      String?
  lat           Float?    // latitude for geo-radius search
  lng           Float?    // longitude for geo-radius search
  isRemote      Boolean   @default(false)
  availability  Json?     // { days: ["Mon","Tue"], hours: "9am-5pm" }

  // Base pricing (packages override this)
  basePrice     Decimal   @db.Decimal(10, 2)
  deliveryDays  Int       @default(3)

  // SEO / search
  searchVector  String?   // for full-text search

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  packages      ServicePackage[]
  orders        Order[]
  conversations Conversation[]

  @@map("services")
}

// ─── SERVICE PACKAGES ────────────────────────────────────────

// Each service can have up to 3 packages: Basic / Standard / Premium
model ServicePackage {
  id            String   @id @default(cuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name          String   // "Basic", "Standard", "Premium"
  description   String
  price         Decimal  @db.Decimal(10, 2)
  deliveryDays  Int
  revisions     Int      @default(1)
  features      String[] // List of included features
  isPopular     Boolean  @default(false)

  orders        Order[]

  @@map("service_packages")
}

// ─── ORDERS ──────────────────────────────────────────────────

model Order {
  id                    String      @id @default(cuid())
  buyerId               String
  buyer                 User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId              String
  seller                User        @relation("SellerOrders", fields: [sellerId], references: [id])
  serviceId             String
  service               Service     @relation(fields: [serviceId], references: [id])
  packageId             String?
  package               ServicePackage? @relation(fields: [packageId], references: [id])

  status                OrderStatus @default(PENDING)
  amount                Decimal     @db.Decimal(10, 2)   // Total charged to buyer
  platformFee           Decimal     @db.Decimal(10, 2)   // Platform's cut (e.g., 10%)
  sellerEarnings        Decimal     @db.Decimal(10, 2)   // amount - platformFee

  // Stripe escrow
  stripePaymentIntentId String?     @unique
  escrowHeld            Boolean     @default(true)
  escrowReleasedAt      DateTime?

  // Delivery info
  requirements          String?     @db.Text  // Buyer's instructions to seller
  deliveryDays          Int
  dueDate               DateTime?
  deliveredAt           DateTime?
  completedAt           DateTime?

  // Booking (for scheduled services)
  scheduledAt           DateTime?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  review                Review?
  dispute               Dispute?
  conversation          Conversation?

  @@map("orders")
}

// ─── REVIEWS ─────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  buyerId     String
  buyer       User     @relation("ReviewsGiven", fields: [buyerId], references: [id])
  sellerId    String
  seller      User     @relation("ReviewsReceived", fields: [sellerId], references: [id])

  rating      Int      // 1–5
  comment     String   @db.Text
  sellerReply String?  // Seller can respond to the review

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reviews")
}

// ─── CONVERSATIONS & MESSAGES ─────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  buyerId     String
  buyer       User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId    String
  seller      User      @relation("SellerConversations", fields: [sellerId], references: [id])
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  orderId     String?   @unique
  order       Order?    @relation(fields: [orderId], references: [id])

  lastMessage String?
  lastMessageAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages    Message[]

  @@unique([buyerId, sellerId, serviceId])
  @@map("conversations")
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation("SentMessages", fields: [senderId], references: [id])

  content         String?      @db.Text
  fileUrl         String?      // Uploaded file URL
  fileName        String?
  fileType        String?      // MIME type

  readAt          DateTime?
  createdAt       DateTime     @default(now())

  @@map("messages")
}

// ─── DISPUTES ────────────────────────────────────────────────

model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  openedById  String        // buyer or seller who opened it

  reason      String        @db.Text
  evidence    String[]      // URLs to uploaded evidence files
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedAt  DateTime?
  resolvedBy  String?       // Admin user id

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("disputes")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?          // Frontend route to navigate to
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ─── REFERRALS ────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id])
  code         String   @unique
  rewardAmount Decimal  @db.Decimal(10, 2) @default(5.00)
  rewardPaid   Boolean  @default(false)
  rewardPaidAt DateTime?
  createdAt    DateTime @default(now())

  @@map("referrals")
}

// ─── PLATFORM SETTINGS ────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
